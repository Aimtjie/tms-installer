# Copy this file to .env and fill in every CHANGE_ME / blank value below
# before `docker compose up`. The compose file reads every variable below.
#
# Variables marked REQUIRED will cause `docker compose up` to abort immediately
# if left blank — this prevents services from starting with insecure defaults.

# ── REQUIRED ────────────────────────────────────────────────────────
# JWT signing secret. Must be ≥ 32 bytes of entropy.
#   openssl rand -base64 48
JWT_SECRET=

# Blind-index HMAC secret for searchable encrypted fields. Must be ≥ 32 bytes.
#   openssl rand -base64 48
# ⚠ Stability: this secret is used to derive blind indexes for email search and
# login lookups. If you change it after the first `docker compose up`, existing
# users will not be findable and login will fail until data is wiped and reseeded.
# Choose a value before first boot and keep it stable for the lifetime of the volume.
BLIND_INDEX_SECRET=

# ── Postgres ────────────────────────────────────────────────────────
# Replace CHANGE_ME with a strong password BEFORE first `docker compose up`.
# It's baked into the postgres data dir on initialisation and cannot be
# changed afterwards without `docker compose down -v` (which wipes the DB).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ── Keycloak ────────────────────────────────────────────────────────
# Replace CHANGE_ME with a strong password BEFORE first `docker compose up`
# — same caveat as Postgres above, the admin user is created on first boot.
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# ── Host ports (change these if 8080/8081/8090 clash with something) ─
# Services bind to 127.0.0.1 by default — only accessible from this machine.
WEB_HTTP_PORT=8081
API_HTTP_PORT=8080
KEYCLOAK_HTTP_PORT=8090

# ── Public URLs ─────────────────────────────────────────────────────
# What the user's browser hits. If you change WEB_HTTP_PORT / API_HTTP_PORT /
# KEYCLOAK_HTTP_PORT above, mirror them here. The API uses WEB_PUBLIC_BASE_URL
# for CORS, WEB_PUBLIC_BASE_URL doubles as the SSO redirect base in non-Development,
# and KEYCLOAK_PUBLIC_BASE_URL is rendered into per-tenant SSO setup instructions
# (and is required by an API fail-fast guard whenever the environment isn't Development).
# Production behind a reverse proxy: set all three to their public HTTPS origins.
WEB_PUBLIC_BASE_URL=http://localhost:8081
API_PUBLIC_BASE_URL=http://localhost:8080
KEYCLOAK_PUBLIC_BASE_URL=http://localhost:8090

# ── Environment ─────────────────────────────────────────────────────
# Development runs DbSeeder (admin@tms.local / Admin@1234) and relaxes some
# non-Dev fail-fast guards. This compose stack is designed for Development only
# — do not switch to Production here. See k8s/ for a production-grade deployment.
ASPNETCORE_ENVIRONMENT=Development

# Two-letter prefix for ticket numbers (e.g. SS-1, SS-2, …).
TICKET_NUMBER_PREFIX=SS

# ── Optional: Bitwarden Secrets Manager ─────────────────────────────
# When both are set, the API's BitwardenSecretsManager configuration provider
# overrides the JWT/Encryption secrets above with values from Bitwarden.
# Leave blank to use the local values above (the default for local evaluation).
BWS_ACCESS_TOKEN=
BWS_ORGANIZATION_ID=

# ── External Postgres (optional) ────────────────────────────────────
# Set PG_HOST to use an existing Postgres instance instead of the bundled
# container. Both ticketdb and keycloakdb must already exist on that server
# (see scripts/postgres-init/01-create-databases.sh).
# POSTGRES_USER and POSTGRES_PASSWORD (above) are used as the connection
# credentials — update them to match your external instance.
# install.sh auto-activates docker-compose.external-pg.yml when PG_HOST is set.
#PG_HOST=
#PG_PORT=5432

# ── Optional: GitHub Secrets Manager (alt. to Bitwarden) ─────────────
# When both GH_SECRETS_TOKEN and GH_SECRETS_REPO are set, the API loads
# secret NAMES from the GitHub REST API and resolves each VALUE from a
# matching env var (GitHub Actions / Codespaces inject these from secrets).
# Convention: `__` in a secret name maps to `:` in configuration
# (e.g. JWT__SECRET → Jwt:Secret), matching .NET's standard convention.
# If both Bitwarden and GitHub are configured, GitHub wins (loaded last).
GH_SECRETS_TOKEN=
GH_SECRETS_REPO=
# Optional: scope to a GitHub Environment (e.g. production, staging)
GH_SECRETS_ENVIRONMENT=
# Optional: prefix to look up env vars by — useful in Codespaces where you
# may want to namespace TMS secrets (e.g. TMS_JWT__SECRET).
GH_SECRETS_PREFIX=
